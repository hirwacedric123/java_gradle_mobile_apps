<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarSchoolDetail"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/school_toolbar"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/white"
        app:title="@string/school_detail_title"
        app:titleTextColor="@color/white" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="@dimen/screen_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                style="@style/school_card_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <ImageView
                        android:id="@+id/imageDetailCampus"
                        android:layout_width="@dimen/school_detail_image"
                        android:layout_height="@dimen/school_detail_image"
                        android:contentDescription="@string/school_field_campus_icon"
                        tools:src="@drawable/school_campus_modern" />

                    <TextView
                        android:id="@+id/textDetailName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/school_form_field_gap"
                        android:gravity="center_horizontal"
                        android:textAppearance="@style/TextAppearance.Material3.HeadlineSmall"
                        android:textColor="@color/text_primary"
                        tools:text="Riverside Academy" />

                    <TextView
                        android:id="@+id/textDetailMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/school_form_field_gap"
                        android:gravity="center_horizontal"
                        android:textAppearance="@style/school_text_body_muted"
                        tools:text="Founded 1962" />

                    <TextView
                        android:id="@+id/textDetailAccredited"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_horizontal"
                        android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                        android:textColor="@color/school_toolbar"
                        tools:text="Accredited" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_spacing"
                android:text="@string/school_courses_heading"
                android:textAppearance="@style/school_text_section_title" />

            <LinearLayout
                android:id="@+id/containerCourses"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/school_form_field_gap"
                android:orientation="vertical" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonEditSchool"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/section_spacing"
                android:text="@string/school_edit"
                app:backgroundTint="@color/school_fab_bg" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
