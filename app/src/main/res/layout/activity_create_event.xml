<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/page_background"
    android:orientation="vertical"
    tools:context=".CreateEventActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCreateEvent"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        app:navigationIconTint="@color/white"
        app:title="@string/create_event_title"
        app:titleTextColor="@color/white" />

    <com.google.android.material.card.MaterialCardView
        style="@style/feature_intro_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_padding"
        android:layout_marginTop="@dimen/school_form_field_gap"
        android:layout_marginEnd="@dimen/screen_padding"
        android:layout_marginBottom="@dimen/school_form_field_gap">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/card_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/create_event_page_headline"
                android:textAppearance="@style/feature_intro_headline" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity3_form_inner_gap"
                android:text="@string/create_event_page_lede"
                android:textAppearance="@style/feature_intro_lede" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="@dimen/screen_padding"
        android:paddingTop="0dp"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="@dimen/recycler_bottom_padding_nav">

        <com.google.android.material.card.MaterialCardView
            style="@style/school_card_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/school_form_field_gap"
            app:cardBackgroundColor="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/create_event_section_details"
                    android:textAppearance="@style/school_text_section_title" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEventTitle"
                    style="@style/school_input_layout_outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/school_form_field_gap"
                    android:hint="@string/create_event_field_title">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEventTitle"
                        style="@style/school_input_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapWords"
                        android:maxLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEventLocation"
                    style="@style/school_input_layout_outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/school_form_field_gap"
                    android:hint="@string/create_event_field_location">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEventLocation"
                        style="@style/school_input_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress|textCapWords"
                        android:maxLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEventDate"
                    style="@style/school_input_layout_outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/school_form_field_gap"
                    android:hint="@string/create_event_field_date">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEventDate"
                        style="@style/school_input_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:focusable="false"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEventTime"
                    style="@style/school_input_layout_outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/school_form_field_gap"
                    android:hint="@string/create_event_field_time">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEventTime"
                        style="@style/school_input_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="time"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEventNotes"
                    style="@style/school_input_layout_outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/school_form_field_gap"
                    android:hint="@string/create_event_field_notes">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editEventNotes"
                        style="@style/school_input_edit_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_spacing"
                    android:text="@string/create_event_field_category"
                    android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                    android:textColor="@color/text_primary" />

                <Spinner
                    android:id="@+id/spinnerEventCategory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/school_form_field_gap"
                    android:minHeight="48dp"
                    android:padding="@dimen/school_spinner_padding" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchEventPublic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_spacing"
                    android:checked="true"
                    android:text="@string/create_event_public_label"
                    android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                    android:textColor="@color/text_primary" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/section_spacing"
                    android:gravity="end"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonCancelEvent"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/create_event_cancel" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSaveEvent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/school_form_field_gap"
                        android:text="@string/create_event_save"
                        app:backgroundTint="@color/tab_indicator" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <include layout="@layout/view_bottom_nav" />
</LinearLayout>
