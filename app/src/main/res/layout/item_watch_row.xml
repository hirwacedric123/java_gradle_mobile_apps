<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/school_card_margin"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/card_corner_lg"
    app:cardElevation="1dp"
    app:strokeColor="@color/card_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <FrameLayout
            android:layout_width="@dimen/watch_thumbnail_width"
            android:layout_height="@dimen/watch_thumbnail_height"
            android:background="@drawable/bg_watch_thumbnail"
            android:contentDescription="@string/cd_watch_clip_thumbnail">

            <ImageView
                android:layout_width="@dimen/watch_play_icon_size"
                android:layout_height="@dimen/watch_play_icon_size"
                android:layout_gravity="center"
                android:importantForAccessibility="no"
                android:scaleType="fitCenter"
                app:srcCompat="@drawable/ic_nav_play"
                app:tint="@color/tab_indicator" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/card_padding"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textWatchTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                android:textColor="@color/text_primary"
                tools:text="SF Jazz Alley highlights" />

            <TextView
                android:id="@+id/textWatchSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity3_form_inner_gap"
                android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
                android:textColor="@color/text_secondary"
                tools:text="Downtown · Live reactions" />

            <TextView
                android:id="@+id/textWatchLength"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/list_row_meta_gap"
                android:background="@drawable/bg_watch_duration_chip"
                android:paddingStart="@dimen/activity3_chip_padding_h"
                android:paddingTop="@dimen/activity3_chip_padding_v"
                android:paddingEnd="@dimen/activity3_chip_padding_h"
                android:paddingBottom="@dimen/activity3_chip_padding_v"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="@color/tab_indicator"
                tools:text="12:04" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
