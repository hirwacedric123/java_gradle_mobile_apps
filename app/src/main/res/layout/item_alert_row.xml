<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/school_card_margin"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/card_corner_lg"
    app:cardElevation="1dp"
    app:strokeColor="@color/card_outline"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/card_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:id="@+id/dotUnread"
                android:layout_width="@dimen/alert_unread_dot_size"
                android:layout_height="@dimen/alert_unread_dot_size"
                android:background="@drawable/bg_alert_dot" />

            <TextView
                android:id="@+id/textAlertTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/school_form_field_gap"
                android:layout_weight="1"
                android:gravity="end"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="@color/text_secondary"
                tools:text="2h ago" />
        </LinearLayout>

        <TextView
            android:id="@+id/textAlertTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/list_row_meta_gap"
            android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
            android:textColor="@color/text_primary"
            tools:text="Reminder · Welcome Back Stacy" />

        <TextView
            android:id="@+id/textAlertSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/activity3_form_inner_gap"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="@color/text_secondary"
            tools:text="Starts tonight at 7:00 PM" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
