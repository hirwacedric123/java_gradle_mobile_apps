<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:elevation="8dp"
    android:gravity="center_vertical"
    android:minHeight="56dp"
    android:orientation="horizontal"
    android:paddingTop="6dp"
    android:paddingBottom="6dp">

    <TextView
        android:id="@+id/bottomNavFeed"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:contentDescription="@string/bottom_nav_feed"
        android:drawablePadding="4dp"
        android:focusable="true"
        android:gravity="center_horizontal"
        android:minHeight="48dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/bottom_nav_feed"
        android:textColor="@color/bottom_icon"
        android:textSize="10sp"
        app:drawableTopCompat="@drawable/ic_nav_video" />

    <TextView
        android:id="@+id/bottomNavWatch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:contentDescription="@string/bottom_nav_watch"
        android:drawablePadding="4dp"
        android:focusable="true"
        android:gravity="center_horizontal"
        android:minHeight="48dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/bottom_nav_watch"
        android:textColor="@color/bottom_icon"
        android:textSize="10sp"
        app:drawableTopCompat="@drawable/ic_nav_play" />

    <TextView
        android:id="@+id/bottomNavShop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:contentDescription="@string/bottom_nav_shop"
        android:drawablePadding="4dp"
        android:focusable="true"
        android:gravity="center_horizontal"
        android:minHeight="48dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/bottom_nav_shop"
        android:textColor="@color/bottom_icon"
        android:textSize="10sp"
        app:drawableTopCompat="@drawable/ic_nav_shop" />

    <TextView
        android:id="@+id/bottomNavAlerts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:contentDescription="@string/bottom_nav_alerts"
        android:drawablePadding="4dp"
        android:focusable="true"
        android:gravity="center_horizontal"
        android:minHeight="48dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/bottom_nav_alerts"
        android:textColor="@color/bottom_icon"
        android:textSize="10sp"
        app:drawableTopCompat="@drawable/ic_nav_globe" />

    <TextView
        android:id="@+id/bottomNavMenu"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:clickable="true"
        android:contentDescription="@string/bottom_nav_menu"
        android:drawablePadding="4dp"
        android:focusable="true"
        android:gravity="center_horizontal"
        android:minHeight="48dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:text="@string/bottom_nav_menu"
        android:textColor="@color/bottom_icon"
        android:textSize="10sp"
        app:drawableTopCompat="@drawable/ic_nav_menu" />
</LinearLayout>
