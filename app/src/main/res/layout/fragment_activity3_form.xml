<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/activity3_surface_bg"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarActivity3Form"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/activity3_toolbar"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@color/white"
        app:titleTextColor="@color/white"
        tools:title="@string/activity3_form_add_title" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:padding="@dimen/screen_padding"
        android:paddingBottom="@dimen/school_form_field_gap">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Project -->
            <com.google.android.material.card.MaterialCardView
                style="@style/activity3_card_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/activity3_section_project"
                        android:textAppearance="@style/activity3_text_section_title" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/activity3_form_inner_gap"
                        android:text="@string/activity3_section_project_subtitle"
                        android:textAppearance="@style/activity3_form_section_subtitle" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/activity3_input_layout_outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/school_form_field_gap"
                        android:hint="@string/activity3_field_title"
                        app:helperText="@string/activity3_helper_title"
                        app:helperTextEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editActivity3Title"
                            style="@style/activity3_input_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/activity3_form_row_gap"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/activity3_input_layout_outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/activity3_form_inner_gap"
                            android:layout_weight="1"
                            android:hint="@string/activity3_field_hours"
                            app:helperText="@string/activity3_helper_hours"
                            app:helperTextEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editActivity3Hours"
                                style="@style/activity3_input_edit_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilActivity3DueDate"
                            style="@style/activity3_input_layout_outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/activity3_field_due_date"
                            app:endIconDrawable="@android:drawable/ic_menu_today"
                            app:endIconMode="custom"
                            app:helperText="@string/activity3_helper_dates"
                            app:helperTextEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editActivity3DueDate"
                                style="@style/activity3_input_edit_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/section_spacing"
                        android:text="@string/activity3_field_image"
                        android:textAppearance="@style/activity3_field_label" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/activity3_form_inner_gap"
                        android:text="@string/activity3_helper_image"
                        android:textAppearance="@style/activity3_form_section_subtitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/school_form_field_gap"
                        android:background="@drawable/bg_activity3_form_inset"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/activity3_preview_padding">

                        <ImageView
                            android:id="@+id/imageActivity3Preview"
                            android:layout_width="@dimen/school_detail_image"
                            android:layout_height="@dimen/school_detail_image"
                            android:contentDescription="@string/activity3_field_image"
                            tools:src="@android:drawable/ic_menu_agenda" />

                        <Spinner
                            android:id="@+id/spinnerActivity3Image"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/card_padding"
                            android:layout_weight="1"
                            android:minHeight="48dp"
                            android:theme="@style/activity3_theme_spinner" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/section_spacing"
                        android:text="@string/activity3_field_status"
                        android:textAppearance="@style/activity3_field_label" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/activity3_form_inner_gap"
                        android:text="@string/activity3_helper_status"
                        android:textAppearance="@style/activity3_form_section_subtitle" />

                    <com.google.android.material.button.MaterialButtonToggleGroup
                        android:id="@+id/toggleActivity3Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/school_form_field_gap"
                        app:checkedButton="@id/toggleActivity3Planned"
                        app:selectionRequired="true"
                        app:singleSelection="true">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleActivity3Planned"
                            style="@style/activity3_toggle_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="@string/activity3_status_planned" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleActivity3Ongoing"
                            style="@style/activity3_toggle_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:text="@string/activity3_status_ongoing" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/toggleActivity3Completed"
                            style="@style/activity3_toggle_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/activity3_status_completed" />
                    </com.google.android.material.button.MaterialButtonToggleGroup>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/section_spacing"
                        app:cardBackgroundColor="@color/activity3_chip_bg"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/activity3_chip_border"
                        app:strokeWidth="1dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:padding="@dimen/card_padding">

                            <CheckBox
                                android:id="@+id/checkActivity3Urgent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:buttonTint="@color/activity3_control_tint" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/school_form_field_gap"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="@string/activity3_urgent_row_title"
                                    android:textAppearance="@style/TextAppearance.Material3.TitleSmall"
                                    android:textColor="@color/text_primary" />

                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:text="@string/activity3_urgent_row_subtitle"
                                    android:textAppearance="@style/activity3_form_section_subtitle" />
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Linked category -->
            <com.google.android.material.card.MaterialCardView
                style="@style/activity3_card_style"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/activity3_form_section_gap"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/activity3_section_category"
                        android:textAppearance="@style/activity3_text_section_title" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/activity3_form_inner_gap"
                        android:text="@string/activity3_section_category_subtitle"
                        android:textAppearance="@style/activity3_form_section_subtitle" />

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/activity3_input_layout_outlined"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/school_form_field_gap"
                        android:hint="@string/activity3_field_category_name">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/editActivity3CategoryName"
                            style="@style/activity3_input_edit_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/activity3_form_row_gap"
                        android:baselineAligned="false"
                        android:orientation="horizontal">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/activity3_input_layout_outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/activity3_form_inner_gap"
                            android:layout_weight="1"
                            android:hint="@string/activity3_field_priority"
                            app:helperText="@string/activity3_helper_priority"
                            app:helperTextEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editActivity3Priority"
                                style="@style/activity3_input_edit_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilActivity3ReviewDate"
                            style="@style/activity3_input_layout_outlined"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="@string/activity3_field_review_date"
                            app:endIconDrawable="@android:drawable/ic_menu_today"
                            app:endIconMode="custom"
                            app:helperText="@string/activity3_helper_dates"
                            app:helperTextEnabled="true">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/editActivity3ReviewDate"
                                style="@style/activity3_input_edit_text"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Sticky actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:elevation="@dimen/activity3_form_footer_elevation"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/activity3_card_stroke" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_padding">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/activity3_actions_hint"
                android:textAppearance="@style/activity3_form_section_subtitle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/school_form_field_gap"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonActivity3Cancel"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/activity3_cancel"
                    android:textColor="@color/activity3_toolbar_dark"
                    app:rippleColor="@color/divider" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonActivity3Save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/school_form_field_gap"
                    android:text="@string/activity3_save"
                    android:textColor="@color/white"
                    app:backgroundTint="@color/activity3_accent"
                    app:rippleColor="@color/activity3_control_ripple" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
